{
  "name": "pi-banana",
  "version": "2.1.3",
  "description": "Generate, edit, and analyze images in pi using Google Nano Banana (image gen) and Gemini Vision (analysis). Inline terminal preview, reference-image editing, auto-save.",
  "author": "Francesco Frapporti <effedue@gmail.com>",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/Fornace/pi-banana#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fornace/pi-banana.git"
  },
  "bugs": {
    "url": "https://github.com/Fornace/pi-banana/issues"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "google",
    "gemini",
    "gemini-api",
    "nano-banana",
    "nano-banana-2",
    "nano-banana-pro",
    "imagen",
    "image-generation",
    "image-editing",
    "ai-image",
    "terminal"
  ],
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "extensions/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "smoke": "node _tmp/smoke.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.52.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@types/node": "^22.0.0",
    "jiti": "^2.7.0",
    "typebox": "^1.1.24",
    "typescript": "^6.0.3"
  }
}
