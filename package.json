{
  "name": "pi-banana",
  "version": "2.0.0",
  "description": "Generate and edit images in pi using Google Nano Banana 2 (gemini-3.1-flash-image) and Nano Banana Pro. Inline terminal preview, reference-image editing, auto-save.",
  "author": "Francesco Frapporti <effedue@gmail.com>",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "google",
    "gemini",
    "nano-banana",
    "nano-banana-2",
    "nano-banana-pro",
    "image-generation",
    "image-edit",
    "imagen"
  ],
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "extensions/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "smoke": "node _tmp/smoke.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.52.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^22.0.0",
    "jiti": "^2.7.0",
    "typebox": "^1.1.24",
    "typescript": "^6.0.3"
  }
}
